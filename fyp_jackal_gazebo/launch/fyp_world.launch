<launch>
  <!-- Gazebo with the FYP arena (bridge + tripod) and the sensor-equipped
       Jackal spawned at the origin, facing the bridge. -->
  <!-- low_bridge:=true loads the variant where the bridge deck (0.50 m) is
       below the robot's sensor tower: 2D-only navigation crashes into it,
       3D navigation correctly refuses to enter. -->
  <arg name="low_bridge" default="false"/>
  <arg name="world_name"
       default="$(eval find('fyp_jackal_gazebo') + ('/worlds/fyp_arena_low_bridge.world' if arg('low_bridge') else '/worlds/fyp_arena.world'))"/>
  <arg name="gui" default="true"/>
  <arg name="headless" default="false"/>

  <arg name="mid360_xyz" default="-0.02 0 0.30"/>
  <arg name="mid360_tilt_deg" default="38.22"/>
  <arg name="mid360_samples" default="10000"/>

  <include file="$(find gazebo_ros)/launch/empty_world.launch">
    <arg name="world_name" value="$(arg world_name)"/>
    <arg name="paused" value="false"/>
    <arg name="use_sim_time" value="true"/>
    <arg name="gui" value="$(arg gui)"/>
    <arg name="headless" value="$(arg headless)"/>
  </include>

  <include file="$(find fyp_jackal_gazebo)/launch/spawn_jackal.launch">
    <arg name="x" value="0"/>
    <arg name="y" value="0"/>
    <arg name="z" value="0.2"/>
    <arg name="yaw" value="0"/>
    <arg name="mid360_xyz" value="$(arg mid360_xyz)"/>
    <arg name="mid360_tilt_deg" value="$(arg mid360_tilt_deg)"/>
    <arg name="mid360_samples" value="$(arg mid360_samples)"/>
  </include>
</launch>
