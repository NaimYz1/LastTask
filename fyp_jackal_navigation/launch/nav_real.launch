<launch>
  <!-- Navigation on the REAL Jackal.
       Prerequisites (see docs/REAL_ROBOT.md):
         * Jackal base running as usual (odom, base_link TF, cmd_vel)
         * Hokuyo publishing /front/scan (your existing setup)
         * livox_ros_driver2 publishing PointCloud2 on /livox/lidar
       Run:
         roslaunch fyp_jackal_navigation nav_real.launch map_file:=/path/to/your_map.yaml
       Then set the initial pose in RViz (2D Pose Estimate) before sending goals. -->
  <arg name="map_file"/>
  <arg name="use_mid360" default="true"/>
  <arg name="clearance" default="0.70"/>

  <!-- ============ Mid-360 mount, measured from base_link ============
       UPDATE THESE after measuring the real robot!
       z = height of the Mid-360 optical centre above base_link
           (base_link sits ~0.065 m above the floor, so z here =
            measured height above floor - 0.065).
       pitch = nose-down tilt in RADIANS (38.22 deg = 0.6671). -->
  <arg name="mid360_x" default="-0.02"/>
  <arg name="mid360_y" default="0.0"/>
  <arg name="mid360_z" default="0.484"/>
  <arg name="mid360_pitch" default="0.6671"/>
  <arg name="mid360_frame" default="livox_frame"/>

  <!-- static_transform_publisher args: x y z yaw pitch roll parent child period_ms -->
  <node pkg="tf" type="static_transform_publisher" name="mid360_static_tf"
        args="$(arg mid360_x) $(arg mid360_y) $(arg mid360_z)
              0 $(arg mid360_pitch) 0
              base_link $(arg mid360_frame) 50"/>

  <node name="map_server" pkg="map_server" type="map_server" args="$(arg map_file)"/>

  <include file="$(find fyp_jackal_navigation)/launch/include/amcl.launch"/>

  <include file="$(find fyp_jackal_navigation)/launch/include/move_base.launch">
    <arg name="use_mid360" value="$(arg use_mid360)"/>
    <arg name="clearance" value="$(arg clearance)"/>
    <arg name="common_params"
         value="$(find fyp_jackal_navigation)/params/costmap_common_real.yaml"/>
  </include>
</launch>
