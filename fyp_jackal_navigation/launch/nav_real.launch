<launch>
  <!-- Navigation on the REAL Jackal (cpr-j100-0540).
       What must already be running (comes up with the robot):
         * Jackal base (odom, base_link TF, /cmd_vel via twist_mux)
         * Hokuyo urg_node publishing /scan (frame "laser")
         * Livox driver publishing PointCloud2 on /livox/lidar
       Run:
         roslaunch fyp_jackal_navigation nav_real.launch
       Then in RViz: 2D Pose Estimate first, then 2D Nav Goal.

       The myroom map ships with this package; override with
       map_file:=/path/to/other_map.yaml for a different room. -->
  <arg name="map_file" default="$(find fyp_jackal_navigation)/maps/myroom.yaml"/>
  <arg name="use_mid360" default="true"/>
  <!-- The obstacle height band is applied by the mid360_filter node,
       RELATIVE TO base_link (which sits ~0.065 m above the floor):
         band_min_z 0.05 -> keep from ~0.12 m above floor (sees the low
                            star-base of the bridge stool; safe against
                            ground noise now that the pitch is measured)
         band_max_z 0.50 -> ignore above ~0.57 m above floor (robot ~0.50 m;
                            the 0.75 m bridge deck stays above the band)
       accumulate: seconds of ego-motion-compensated point history, so thin
       obstacles (tripod legs) stay solidly marked against raytrace clearing.
       clearance stays 10.0 here: the costmap-side height filter is
       deliberately wide open, the filter node is the real gate. -->
  <arg name="band_min_z" default="0.05"/>
  <arg name="band_max_z" default="0.50"/>
  <arg name="accumulate" default="1.5"/>
  <arg name="clearance" default="10.0"/>
  <arg name="max_vel" default="0.5"/>
  <!-- fast:=true for snappier decisions and quicker turns (demo pace). -->
  <arg name="fast" default="false"/>
  <!-- Wipe costmaps every N seconds (0 = off). Stops global-costmap mark
       smear from AMCL jitter sealing narrow corridors over a run; safe
       because the mid360_filter window re-marks everything within 0.1 s. -->
  <arg name="clear_period" default="10.0"/>
  <arg name="scan_topic" default="scan"/>

  <!-- Mount values, MEASURED with measure_tilt.py on 2026-07-13:
       nose-down pitch 38.73 deg (0.6759 rad), sensor 0.440 m above the
       floor -> z = 0.375 from base_link. (The 45 deg static TF from the
       peer's amr_system is mis-calibrated by ~6 deg; the old 38.22 design
       figure was nearly right.) These feed the mid360_filter node. -->
  <arg name="mid360_x" default="0.179"/>
  <arg name="mid360_y" default="0.0"/>
  <arg name="mid360_z" default="0.375"/>
  <arg name="mid360_pitch" default="0.6759"/>
  <arg name="mid360_frame" default="livox_frame"/>

  <!-- Navigation does NOT use livox_frame TF at all anymore (the
       mid360_filter node applies the mount transform itself). Something on
       this robot publishes livox_frame with stale stamps (TF_OLD_DATA from
       an unknown_publisher), so we stay out of that fight: default false.
       Set true only if you want the raw /livox/lidar cloud overlaid in
       RViz and nothing else is publishing the frame. -->
  <arg name="publish_mid360_tf" default="false"/>

  <!-- static_transform_publisher args: x y z yaw pitch roll parent child period_ms -->
  <node pkg="tf" type="static_transform_publisher" name="mid360_static_tf"
        args="$(arg mid360_x) $(arg mid360_y) $(arg mid360_z)
              0 $(arg mid360_pitch) 0
              base_link $(arg mid360_frame) 50"
        if="$(arg publish_mid360_tf)"/>

  <!-- Only if the robot does NOT already publish base_link -> laser
       (check with: rosrun tf tf_echo base_link laser). Hokuyo optical
       centre ~0.355 m above floor -> z = 0.29. -->
  <arg name="publish_laser_tf" default="false"/>
  <arg name="laser_x" default="0.08"/>
  <arg name="laser_z" default="0.29"/>
  <node pkg="tf" type="static_transform_publisher" name="laser_static_tf"
        args="$(arg laser_x) 0 $(arg laser_z) 0 0 0 base_link laser 50"
        if="$(arg publish_laser_tf)"/>

  <!-- TF-free Mid-360 obstacle filter: raw /livox/lidar -> height-banded
       /mid360/obstacles in base_link frame (see scripts/mid360_filter.py). -->
  <node pkg="fyp_jackal_navigation" type="mid360_filter.py" name="mid360_filter" output="screen">
    <param name="mount_x" value="$(arg mid360_x)"/>
    <param name="mount_y" value="$(arg mid360_y)"/>
    <param name="mount_z" value="$(arg mid360_z)"/>
    <param name="mount_pitch" value="$(arg mid360_pitch)"/>
    <param name="min_z" value="$(arg band_min_z)"/>
    <param name="max_z" value="$(arg band_max_z)"/>
    <param name="accumulate" value="$(arg accumulate)"/>
  </node>

  <node name="map_server" pkg="map_server" type="map_server" args="$(arg map_file)"/>

  <node pkg="fyp_jackal_navigation" type="costmap_janitor.py" name="costmap_janitor"
        output="screen">
    <param name="period" value="$(arg clear_period)"/>
  </node>

  <include file="$(find fyp_jackal_navigation)/launch/include/amcl.launch">
    <arg name="scan_topic" value="$(arg scan_topic)"/>
  </include>

  <include file="$(find fyp_jackal_navigation)/launch/include/move_base.launch">
    <arg name="use_mid360" value="$(arg use_mid360)"/>
    <arg name="clearance" value="$(arg clearance)"/>
    <arg name="common_params"
         value="$(find fyp_jackal_navigation)/params/costmap_common_real.yaml"/>
    <arg name="common_params_2d"
         value="$(find fyp_jackal_navigation)/params/costmap_common_2donly_real.yaml"/>
    <arg name="local_costmap_params"
         value="$(find fyp_jackal_navigation)/params/local_costmap_real.yaml"/>
    <arg name="global_costmap_params"
         value="$(find fyp_jackal_navigation)/params/global_costmap_real.yaml"/>
    <arg name="max_vel" value="$(arg max_vel)"/>
    <arg name="fast" value="$(arg fast)"/>
  </include>
</launch>
