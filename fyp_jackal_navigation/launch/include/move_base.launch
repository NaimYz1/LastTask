<launch>
  <arg name="use_mid360" default="true"/>
  <arg name="clearance" default="0.70"/>
  <!-- Which "common" costmap files to use (sim defaults here;
       nav_real.launch passes the real-robot variants). -->
  <arg name="common_params" default="$(find fyp_jackal_navigation)/params/costmap_common.yaml"/>
  <arg name="common_params_2d" default="$(find fyp_jackal_navigation)/params/costmap_common_2donly.yaml"/>
  <arg name="local_costmap_params" default="$(find fyp_jackal_navigation)/params/local_costmap.yaml"/>
  <arg name="global_costmap_params" default="$(find fyp_jackal_navigation)/params/global_costmap.yaml"/>
  <!-- Top driving speed (m/s). Default matches base_local_planner.yaml. -->
  <arg name="max_vel" default="0.5"/>
  <!-- fast:=true - snappier decisions, more risk, base yaml untouched:
       quicker in-place rotation (the "thinking" spin is really just slow
       commanded rotation), short patience before replan/recovery, faster
       recovery spins, loose goal tolerances (no final heading pirouette),
       shorter lookahead. -->
  <arg name="fast" default="false"/>
  <!-- planner:=teb - smooth car-like arcs via teb_local_planner (needs
       ros-melodic-teb-local-planner installed). Default keeps the stock
       TrajectoryPlanner behaviour. -->
  <arg name="planner" default="trajectory"/>
  <!-- TEB only: 0.0 = diff-drive (tight arcs allowed), 0.15-0.30 = strictly
       car-like turning circles. -->
  <arg name="turn_radius" default="0.0"/>
  <!-- park:=true - after reaching the goal position, rotate in place
       (skid-steer) until the robot matches the 2D Nav Goal arrow heading.
       park:=false - stop at the position with whatever heading it arrived. -->
  <arg name="park" default="true"/>

  <node pkg="move_base" type="move_base" respawn="false" name="move_base" output="screen">
    <param name="base_global_planner" value="navfn/NavfnROS"/>
    <param name="base_local_planner" value="base_local_planner/TrajectoryPlannerROS"
           unless="$(eval planner == 'teb')"/>
    <param name="base_local_planner" value="teb_local_planner/TebLocalPlannerROS"
           if="$(eval planner == 'teb')"/>
    <!-- Without tolerance, a goal clicked within the inscribed ring of any
         furniture makes navfn fail instantly and deterministically
         ("Failed to find a valid plan"). With it, navfn plans to the best
         reachable cell within 0.35 m of the click. -->
    <param name="NavfnROS/default_tolerance" value="0.35"/>
    <param name="controller_frequency" value="10.0"/>
    <!-- TEB's optimizer is heavier per cycle; 8 Hz keeps it comfortably
         inside its budget instead of missing the 10 Hz loop. -->
    <param name="controller_frequency" value="8.0" if="$(eval planner == 'teb')"/>
    <param name="planner_frequency" value="2.0"/>

    <!-- Recovery ladder. The stock behaviors only clear marks FAR from the
         robot (3.0 m / 1.84 m), so phantom marks pinching the robot at
         close range survive every recovery and the goal aborts - until a
         restart wipes the costmaps and the same goal suddenly works. The
         extra full_reset stage clears BOTH costmaps completely (back to
         the static map); real obstacles are re-marked by the sensors
         within a frame or two, phantom residue is gone for good. -->
    <rosparam>
      recovery_behaviors:
        - {name: conservative_reset, type: clear_costmap_recovery/ClearCostmapRecovery}
        - {name: rotate_recovery, type: rotate_recovery/RotateRecovery}
        - {name: full_reset, type: clear_costmap_recovery/ClearCostmapRecovery}
        - {name: rotate_recovery2, type: rotate_recovery/RotateRecovery}
      conservative_reset: {reset_distance: 2.0}
      full_reset: {reset_distance: 0.0, force_updating: true}
    </rosparam>

    <rosparam file="$(arg common_params)"
              command="load" ns="global_costmap" if="$(arg use_mid360)"/>
    <rosparam file="$(arg common_params)"
              command="load" ns="local_costmap" if="$(arg use_mid360)"/>
    <rosparam file="$(arg common_params_2d)"
              command="load" ns="global_costmap" unless="$(arg use_mid360)"/>
    <rosparam file="$(arg common_params_2d)"
              command="load" ns="local_costmap" unless="$(arg use_mid360)"/>

    <rosparam file="$(arg local_costmap_params)" command="load"/>
    <rosparam file="$(arg global_costmap_params)" command="load"/>
    <rosparam file="$(find fyp_jackal_navigation)/params/base_local_planner.yaml" command="load"/>
    <rosparam file="$(find fyp_jackal_navigation)/params/teb_local_planner.yaml"
              command="load" if="$(eval planner == 'teb')"/>

    <!-- Overhead clearance override (must come AFTER the rosparam loads):
         Mid-360 points above this height (metres, floor frame) are ignored,
         because the robot can pass underneath them. -->
    <param name="global_costmap/obstacles_layer/mid360/max_obstacle_height"
           value="$(arg clearance)" if="$(arg use_mid360)"/>
    <param name="local_costmap/obstacles_layer/mid360/max_obstacle_height"
           value="$(arg clearance)" if="$(arg use_mid360)"/>

    <!-- Speed override (after the rosparam load so it wins). -->
    <param name="TrajectoryPlannerROS/max_vel_x" value="$(arg max_vel)"/>
    <param name="TebLocalPlannerROS/max_vel_x" value="$(arg max_vel)"
           if="$(eval planner == 'teb')"/>
    <param name="TebLocalPlannerROS/min_turning_radius" value="$(arg turn_radius)"
           if="$(eval planner == 'teb')"/>

    <!-- fast-mode overrides (document order: these win over the yaml).
         planner_frequency deliberately NOT raised: 4 Hz replanning made
         near-equal-cost routes flap side to side, and each flip triggered
         escape reverses ("backing up with nothing in front") and visible
         wrong-way excursions. -->
    <param name="planner_patience" value="2.0" if="$(arg fast)"/>
    <param name="controller_patience" value="4.0" if="$(arg fast)"/>
    <param name="TrajectoryPlannerROS/max_vel_theta" value="1.2" if="$(arg fast)"/>
    <param name="TrajectoryPlannerROS/min_vel_theta" value="-1.2" if="$(arg fast)"/>
    <param name="TrajectoryPlannerROS/min_in_place_vel_theta" value="0.6" if="$(arg fast)"/>
    <param name="TrajectoryPlannerROS/max_rotational_vel" value="1.0" if="$(arg fast)"/>
    <param name="TrajectoryPlannerROS/escape_vel" value="-0.15" if="$(arg fast)"/>
    <param name="TrajectoryPlannerROS/sim_time" value="1.5" if="$(arg fast)"/>
    <param name="TrajectoryPlannerROS/xy_goal_tolerance" value="0.3" if="$(arg fast)"/>
    <param name="TebLocalPlannerROS/xy_goal_tolerance" value="0.3"
           if="$(eval fast and planner == 'teb')"/>

    <!-- Parking: latch the position once reached, then align to the goal
         arrow heading with an in-place rotation - or ignore heading
         entirely with park:=false. -->
    <param name="TrajectoryPlannerROS/latch_xy_goal_tolerance" value="true"/>
    <param name="TrajectoryPlannerROS/yaw_goal_tolerance" value="0.25" if="$(arg park)"/>
    <param name="TrajectoryPlannerROS/yaw_goal_tolerance" value="6.28" unless="$(arg park)"/>
    <param name="TebLocalPlannerROS/yaw_goal_tolerance" value="0.25"
           if="$(eval park and planner == 'teb')"/>
    <param name="TebLocalPlannerROS/yaw_goal_tolerance" value="6.28"
           if="$(eval (not park) and planner == 'teb')"/>
  </node>
</launch>
